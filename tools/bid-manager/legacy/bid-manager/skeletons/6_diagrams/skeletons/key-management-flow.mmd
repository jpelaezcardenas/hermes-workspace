%% DALP key management lifecycle.
%% Shows key generation, storage, signing request, approval, execution, on-chain submission.
%% Use in security, custody, key management, and cryptographic controls sections.
%% Evaluator focus: separation of duties, no single point of compromise, cryptographic hygiene.
%%{init: {
  "theme": "base",
  "themeVariables": {"fontFamily": "Figtree, Inter, Arial, sans-serif", "fontSize": "15px", "textColor": "#1A1A2E", "lineColor": "#6B7280", "background": "#FFFFFF"},
  "sequence": {"mirrorActors": false, "showSequenceNumbers": false, "diagramMarginX": 40, "diagramMarginY": 20, "messageMargin": 28, "boxMargin": 12, "actorMargin": 40, "width": 170, "height": 64},
  "securityLevel": "loose"
