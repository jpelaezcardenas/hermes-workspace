%% Client-facing solution architecture.
%% Use in target solution, integration overview, and deployment model sections.
%% Replace [CLIENT: ...] systems with the actual enterprise landscape in scope.
%%{init: {
  "theme": "base",
  "themeVariables": {"fontFamily": "Figtree, Inter, Arial, sans-serif", "fontSize": "15px", "textColor": "#1A1A2E", "lineColor": "#6B7280", "background": "#FFFFFF", "clusterBkg": "#FAFAFA", "clusterBorder": "#D0D7DE", "edgeLabelBackground": "#FFFFFF"},
