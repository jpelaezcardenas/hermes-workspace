flowchart LR
    %% User access paths
    USERS[Issuer And Operations Users]
    SSO[SSO / IdP]
    APIUSERS[Client Applications]

    %% DALP platform core
    subgraph DALP[DALP Platform]
        AC[Asset Console]
        UAPI[Unified API]
        EE[Execution Engine]
        CI[Chain Indexer]
        KG[Key Guardian]
        CHAIN[SMART Protocol Assets]
    end

    %% Client systems
    subgraph CLIENT[Client Systems]
        CBS[[CLIENT: Core Banking]]
        ERP[[CLIENT: ERP / Finance]]
        CRM[[CLIENT: CRM / Investor Portal]]
        DATA[[CLIENT: Data Lake / BI]]
    end

    %% External integrations
    subgraph EXT[External Services]
        KYC[KYC / AML Provider]
        CUST[Custody Provider]
        MD[Market Data Provider]
        PAY[Payment Rails]
        RPC[Blockchain RPC Network]
    end

    USERS --> AC
    SSO --> AC
    APIUSERS --> UAPI

    AC --> UAPI
    UAPI --> EE
    UAPI --> CI
    EE --> KG
    EE --> CHAIN
    CI --> CHAIN
    CHAIN --> RPC

    UAPI <--> CBS
    UAPI <--> ERP
    UAPI <--> CRM
    CI --> DATA

    EE <--> KYC
    EE <--> CUST
    EE <--> MD
    EE <--> PAY

    %% Optional client channels
    CHANNEL[[CLIENT: Distribution Channels]] --> UAPI
    REPORT[[CLIENT: Reporting Stack]] <-- CI

    classDef rounded rx:10,ry:10;
    classDef dalp fill:#E8F4FD,stroke:#5B8DEF,color:#1A1A2E,stroke-width:1.5px;
    classDef client fill:#E8F5E9,stroke:#66BB6A,color:#1A1A2E,stroke-width:1.5px;
    classDef external fill:#FFF3E0,stroke:#FB8C00,color:#1A1A2E,stroke-width:1.5px;
    classDef compliance fill:#F3E5F5,stroke:#8E63CE,color:#1A1A2E,stroke-width:1.5px;
    classDef infra fill:#F5F5F5,stroke:#90A4AE,color:#1A1A2E,stroke-width:1.5px;

    class USERS,SSO,APIUSERS client,rounded;
    class AC,UAPI,CHAIN dalp,rounded;
    class EE,CI,KG infra,rounded;
    class CBS,ERP,CRM,DATA,CHANNEL,REPORT client,rounded;
    class KYC,CUST,MD,PAY,RPC external,rounded;
