flowchart LR
    USERS[Client Users]
    APIAPP[Client API Consumers]
    WAF[WAF / Ingress]
    LB[Load Balancer]

    subgraph SAAS[SettleMint SaaS Environment]
        K8S[Multi-Tenant K8s Cluster]
        APP[DALP Services]
        IDX[Chain Indexer]
        DB[Managed PostgreSQL]
        OBJ[Object Storage]
        KMS[KMS / HSM]
        OBS[Observability Stack]
    end

    subgraph CHAIN[Blockchain Access]
        GW[Chain Gateway]
        RPC[RPC Providers]
        NODE[Blockchain Nodes]
    end

    USERS --> WAF --> LB --> K8S
    APIAPP --> WAF
    K8S --> APP
    K8S --> IDX
    APP --> DB
    APP --> OBJ
    APP --> KMS
    APP --> OBS
    IDX --> DB
    APP --> GW
    IDX --> GW
    GW --> RPC
    RPC --> NODE

    TENANT[[CLIENT: Tenant Configuration]] --> APP

