#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
from pathlib import Path
from datetime import datetime, timezone

ROOT = Path('/root/hermes-workspace/tools/dalp-for-x')
LEGACY = ROOT / 'legacy' / 'dalp-for-x'
VERIFICATION = ROOT / 'verification'


def count_files(path: Path, suffix: str):
    return sum(1 for p in path.rglob(f'*{suffix}') if p.is_file())


def load_json(path: Path):
    return json.loads(path.read_text())


def status(_args):
    registry = (LEGACY / 'setup' / 'TARGET-REGISTRY.md').read_text().splitlines()
    queue = (LEGACY / 'setup' / 'BACKFILL-QUEUE.md').read_text().splitlines()
    content_files = count_files(LEGACY / 'content', '.json')
    setup_files = count_files(LEGACY / 'setup', '.md')
    return {
        'agent': 'dalp-for-x',
        'timestamp': datetime.now(timezone.utc).isoformat(),
        'legacy_root': str(LEGACY),
        'content_json_files': content_files,
        'setup_markdown_files': setup_files,
        'registry_lines': len(registry),
        'queue_lines': len(queue),
        'active_wrapper': str(Path(__file__).resolve()),
    }


def smoke(_args):
    content_dir = LEGACY / 'content'
    sample = load_json(content_dir / 'japan.json')
    out = {
        'agent': 'dalp-for-x',
        'checks': {
            'legacy_tree_present': LEGACY.exists(),
            'content_dir_present': content_dir.exists(),
            'sample_json_parse': isinstance(sample, dict) and 'hero' in sample,
            'readme_present': (LEGACY / 'README.md').exists(),
            'rules_present': (LEGACY / 'setup' / 'RULES.md').exists(),
        },
    }
    out['passed'] = all(out['checks'].values())
    return out


def golden(_args):
    registry = (LEGACY / 'setup' / 'TARGET-REGISTRY.md').read_text()
    queue = (LEGACY / 'setup' / 'BACKFILL-QUEUE.md').read_text()
    page_count = registry.count('|')
    done_count = queue.count('|')
    out = {
        'agent': 'dalp-for-x',
        'checks': {
            'registry_mentions_published': 'published' in registry,
            'queue_mentions_done': 'done' in queue,
            'registry_has_spain': 'spain' in registry,
            'registry_has_belgium': 'belgium' in registry,
            'registry_has_united_states': 'united-states' in registry,
        },
        'signals': {
            'registry_pipe_count': page_count,
            'queue_pipe_count': done_count,
        }
    }
    out['passed'] = all(out['checks'].values())
    return out


def main():
    parser = argparse.ArgumentParser(prog='dalp-for-x')
    sub = parser.add_subparsers(dest='cmd', required=True)
    for name in ('status', 'smoke', 'golden-regressions'):
        sub.add_parser(name)
    args = parser.parse_args()
    if args.cmd == 'status':
        result = status(args)
    elif args.cmd == 'smoke':
        result = smoke(args)
    else:
        result = golden(args)
    print(json.dumps(result, indent=2, sort_keys=True))


if __name__ == '__main__':
    main()
