#!/root/hermes-workspace/tools/ppt-maker/.venv/bin/python
"""Canonical ppt-maker runtime wrapper.

Wraps the recovered SettleMint office-agent PPT Maker and PPT Checker surfaces
behind one stable command line without mutating the preserved brain mirror.
"""
from __future__ import annotations

import argparse
import json
import os
import subprocess
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
LEGACY = ROOT / "legacy"
OFFICE_AGENTS = ROOT / "settlemint-office-agents"
PPT = LEGACY / "ppt-maker"
CHECKER = LEGACY / "ppt-checker"
OUTPUT = OFFICE_AGENTS / "ppt-maker" / "output"
ACTIVE = ROOT / "active"

SCRIPT_MAP = {
    "build-config": PPT / "scripts" / "build_from_config.py",
    "generate-review": CHECKER / "scripts" / "generate_review.py",
    "export-review-docx": CHECKER / "scripts" / "export_review_docx.py",
    "inspect": CHECKER / "scripts" / "inspect-pptx.py",
    "validate": CHECKER / "scripts" / "validate_deck.py",
    "golden-regressions": ACTIVE / "runtime-scripts" / "run_golden_regressions.py",
    "visual-regression": ACTIVE / "runtime-scripts" / "run_visual_regression.py",
    "final-artifact-qa": ACTIVE / "runtime-scripts" / "run_final_artifact_qa.py",
}


def ensure_layout() -> None:
    ROOT.mkdir(parents=True, exist_ok=True)
    OUTPUT.mkdir(parents=True, exist_ok=True)
    if not OFFICE_AGENTS.exists():
        OFFICE_AGENTS.symlink_to(LEGACY, target_is_directory=True)


def normalize_args(args: list[str]) -> list[str]:
    out: list[str] = []
    for arg in args:
        if not arg or arg.startswith("-") or "://" in arg:
            out.append(arg)
            continue
        looks_like_path = ("/" in arg) or ("\\" in arg) or Path(arg).suffix
        if not looks_like_path:
            out.append(arg)
            continue
        candidate = ROOT / arg
        if candidate.exists() or candidate.parent.exists():
            out.append(str(candidate.resolve()))
        else:
            out.append(arg)
    return out


def run_script(name: str, args: list[str]) -> int:
    ensure_layout()
    script = SCRIPT_MAP[name]
    if not script.exists():
        print(f"Missing script for {name}: {script}", file=sys.stderr)
        return 2
    env = os.environ.copy()
    env.setdefault("PPT_MAKER_HOME", str(ROOT))
    env.setdefault("PYTHONPATH", f"{PPT / 'scripts'}:{CHECKER / 'scripts'}:{env.get('PYTHONPATH','')}")
    cwd = str(PPT if name in {"build-config", "golden-regressions"} else CHECKER)
    return subprocess.call([sys.executable, str(script), *normalize_args(args)], cwd=cwd, env=env)


def inventory(root: Path) -> dict:
    files = dirs = symlinks = bytes_ = 0
    for dirpath, dirnames, filenames in os.walk(root, followlinks=False):
        for d in dirnames:
            p = Path(dirpath) / d
            if p.is_symlink():
                symlinks += 1
            else:
                dirs += 1
        for f in filenames:
            p = Path(dirpath) / f
            if p.is_symlink():
                symlinks += 1
            else:
                files += 1
                try:
                    bytes_ += p.stat().st_size
                except OSError:
                    pass
    return {"files": files, "dirs": dirs, "symlinks": symlinks, "bytes": bytes_}


def cmd_status(_: argparse.Namespace) -> int:
    ensure_layout()
    payload = {
        "agent": "ppt-maker",
        "root": str(ROOT),
        "output_root": str(OUTPUT),
        "surfaces": {
            "ppt-maker": inventory(PPT),
            "ppt-checker": inventory(CHECKER),
        },
        "commands": sorted(SCRIPT_MAP),
    }
    print(json.dumps(payload, indent=2))
    return 0


def cmd_smoke(_: argparse.Namespace) -> int:
    ensure_layout()
    checks = [{"command": name, "script": str(script), "exists": script.exists()} for name, script in SCRIPT_MAP.items()]
    py_files = [str(p) for p in SCRIPT_MAP.values() if p.exists() and p.suffix == ".py"]
    proc = subprocess.run([sys.executable, "-m", "py_compile", *py_files], cwd=str(ROOT), text=True, capture_output=True)
    template = PPT / "templates" / "Master Template 2026.pptx"
    slide_bank = PPT / "slide-bank"
    payload = {
        "agent": "ppt-maker",
        "script_checks": checks,
        "template_exists": template.exists(),
        "slide_bank_pptx_count": len(list(slide_bank.glob("*.pptx"))) if slide_bank.exists() else 0,
        "compile_exit_code": proc.returncode,
        "compile_stdout": proc.stdout[-2000:],
        "compile_stderr": proc.stderr[-4000:],
        "ok": all(c["exists"] for c in checks) and template.exists() and proc.returncode == 0,
    }
    print(json.dumps(payload, indent=2))
    return 0 if payload["ok"] else 1


def cmd_render_pdf(ns: argparse.Namespace) -> int:
    ensure_layout()
    src = Path(normalize_args([ns.pptx])[0]).resolve()
    out_dir = Path(normalize_args([ns.out_dir])[0]).resolve() if ns.out_dir else src.parent
    out_dir.mkdir(parents=True, exist_ok=True)
    proc = subprocess.run(["libreoffice", "--headless", "--convert-to", "pdf", "--outdir", str(out_dir), str(src)], text=True, capture_output=True)
    payload = {"input": str(src), "out_dir": str(out_dir), "exit": proc.returncode, "stdout": proc.stdout[-2000:], "stderr": proc.stderr[-2000:], "pdf": str(out_dir / (src.stem + ".pdf")), "ok": proc.returncode == 0 and (out_dir / (src.stem + ".pdf")).exists()}
    print(json.dumps(payload, indent=2))
    return 0 if payload["ok"] else 1


def passthrough(name: str):
    def _cmd(ns: argparse.Namespace) -> int:
        return run_script(name, ns.args)
    return _cmd


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(prog="ppt-maker", description="Canonical SettleMint ppt-maker runtime wrapper")
    sub = parser.add_subparsers(dest="command", required=True)
    p = sub.add_parser("status", help="Show active ppt-maker wiring and inventory")
    p.set_defaults(func=cmd_status)
    p = sub.add_parser("smoke", help="Verify recovered script presence and Python syntax")
    p.set_defaults(func=cmd_smoke)
    p = sub.add_parser("render-pdf", help="Render a PPTX to PDF with LibreOffice")
    p.add_argument("pptx")
    p.add_argument("out_dir", nargs="?")
    p.set_defaults(func=cmd_render_pdf)
    for name in sorted(SCRIPT_MAP):
        p = sub.add_parser(name, help=f"Run recovered {name} script")
        p.add_argument("args", nargs=argparse.REMAINDER)
        p.set_defaults(func=passthrough(name))
    ns, extra = parser.parse_known_args(argv)
    if extra and hasattr(ns, "args"):
        ns.args.extend(extra)
    elif extra:
        parser.error("unrecognized arguments: " + " ".join(extra))
    return ns.func(ns)


if __name__ == "__main__":
    raise SystemExit(main())
