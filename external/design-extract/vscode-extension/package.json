{
  "name": "designlang-vscode",
  "displayName": "designlang",
  "description": "Extract design tokens from any website, right from VS Code.",
  "version": "0.1.0",
  "publisher": "masyv",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Manavarya09/design-extract"
  },
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other", "Themes"],
  "keywords": ["design tokens", "tailwind", "css", "figma", "design system", "extract"],
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "designlang.extractFromUrl",
        "title": "designlang: Extract design from URL"
      },
      {
        "command": "designlang.extractAndInject",
        "title": "designlang: Extract and inject into workspace"
      }
    ],
    "configuration": {
      "title": "designlang",
      "properties": {
        "designlang.outputDir": {
          "type": "string",
          "default": "./design-extract-output",
          "description": "Directory to write extracted design files into, relative to the workspace root."
        },
        "designlang.extraArgs": {
          "type": "string",
          "default": "",
          "description": "Additional CLI args passed to designlang (e.g. --full --selector .pricing)."
        }
      }
    }
  },
  "scripts": {
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0"
  }
}
